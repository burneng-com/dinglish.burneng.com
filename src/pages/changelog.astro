---
import Layout from '../layouts/Layout.astro';
import changelog from '../../CHANGELOG.md?raw';
import pkg from '../../package.json';

const version = pkg.version;

function mdToHtml(md: string) {
  return md
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/^# (.+)$/gm, '<h1>$1</h1>')
    .replace(/^- (.+)$/gm, '<li>$1</li>')
    .replace(/(<li>.*<\/li>\n?)+/gs, (m) => `<ul>${m}</ul>`)
    .replace(/\n{2,}/g, '<br>')
    .replace(/\n/g, '');
}
---

<Layout title={`Changelog — Dinglish Garden ${version}`}>
  <div class="changelog-page">
    <a href="/" class="back-btn">← Back</a>
    <h1>Changelog</h1>
    <div class="changelog-content" set:html={mdToHtml(changelog)} />
    <div class="version-info">Current: {version}</div>
  </div>
</Layout>

<style>
  .changelog-page {
    max-width: 640px;
    margin: 0 auto;
    padding: 24px 16px 40px;
    color: var(--text-primary, #2d3436);
  }
  .back-btn {
    display: inline-block;
    margin-bottom: 16px;
    color: var(--primary, #4a9d5b);
    text-decoration: none;
    font-size: 0.9rem;
  }
  .back-btn:hover { text-decoration: underline; }
  h1 {
    font-size: 1.5rem;
    margin-bottom: 20px;
    color: var(--primary, #4a9d5b);
  }
  h2 {
    font-size: 1.15rem;
    margin-top: 24px;
    margin-bottom: 8px;
    color: var(--text-primary, #2d3436);
    border-bottom: 1px solid var(--border, #e0e0e0);
    padding-bottom: 6px;
  }
  h3 {
    font-size: 0.95rem;
    margin-top: 12px;
    margin-bottom: 4px;
    color: var(--text-secondary, #636e72);
  }
  ul {
    padding-left: 20px;
    margin: 4px 0 8px;
  }
  li {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--text-secondary, #636e72);
  }
  .version-info {
    margin-top: 32px;
    font-size: 0.75rem;
    color: var(--text-secondary, #636e72);
    opacity: 0.6;
  }
</style>
